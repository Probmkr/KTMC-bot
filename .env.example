# Discord Bot のトークン（Discord Developer Portal > Bot > Token）
BOT_TOKEN=

# Bot のクライアント ID（Discord Developer Portal > General Information > Application ID）
APP_ID=

# 開発用サーバーの ID（開発時のみ設定。本番では削除するとグローバルコマンドとして登録される）
GUILD_ID=

# PostgreSQL の接続 URL
# 例: postgresql://user:password@localhost:5432/ktmc
DATABASE_URL=
