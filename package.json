{
  "name": "ktmc-bot",
  "version": "1.0.0",
  "description": "コミュニティ向け多機能 Discord Bot。入退室ログ、モデレーション、その他の機能を提供します。",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "ts-node -r tsconfig-paths/register src/deploy-commands.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Probmkr/KTMC-bot.git"
  },
  "author": "Probmkr",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Probmkr/KTMC-bot/issues"
  },
  "homepage": "https://github.com/Probmkr/KTMC-bot#readme",
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
