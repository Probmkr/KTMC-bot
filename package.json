{
  "name": "ktmc-bot",
  "version": "1.0.0",
  "description": "コミュニティ向け多機能 Discord Bot。入退室ログ、モデレーション、その他の機能を提供します。",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "ts-node -r tsconfig-paths/register src/deploy-commands.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Probmkr/KTMC-bot.git"
  },
  "author": "Probmkr",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Probmkr/KTMC-bot/issues"
  },
  "homepage": "https://github.com/Probmkr/KTMC-bot#readme",
  "dependencies": {
    "discord.js": "^14.26.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
